include preBlock.pug

doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover")
    title= title
    style
      include styles.css
  body
    .card
      .page-title
        h1= title
      .sub= subtitle

      each item in blocks
        +preBlock(item)

    script
      include copy.js
