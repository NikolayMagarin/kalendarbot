mixin preBlock(contentBlock)
  .pre-container
    .pre-header
      span.label= contentBlock.label
      button.copy-btn(data-target=contentBlock.id, aria-label="Copy to clipboard")
        svg(viewBox="0 0 24 24" width="16" height="16")
          rect(x="9" y="9" width="13" height="13" rx="2" ry="2" stroke="currentColor" fill="none")
          path(d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" stroke="currentColor" fill="none")
        span.btn-text Копировать
    pre(id=contentBlock.id)= contentBlock.content
